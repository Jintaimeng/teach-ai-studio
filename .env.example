# CodeBuddy Agent SDK 配置
# 复制此文件为 .env 并填入你的 API Key

# 方式一：使用 API Key（推荐）
CODEBUDDY_API_KEY=your_api_key_here

# 方式二：使用 Auth Token（备选）
# CODEBUDDY_AUTH_TOKEN=your_auth_token_here

# 可选：自定义 Base URL（如使用私有部署）
# CODEBUDDY_BASE_URL=https://api.codebuddy.cn

# 可选：网络环境（external / internal）
# CODEBUDDY_INTERNET_ENVIRONMENT=external

# 服务端口（默认 3000）
PORT=3000

# ===== 多用户鉴权（JWT）=====
# 生产环境必须设置为高强度随机字符串，否则使用不安全的默认值
JWT_SECRET=please_change_me_to_a_long_random_secret
# JWT 有效期（默认 7d）
# JWT_EXPIRES_IN=7d

# ===== agent 并发护栏 =====
# 同时允许的 query() 子进程数上限，超出排队（默认 20）
AGENT_MAX_CONCURRENCY=20

# ===== yanbot 开放接口（志愿推荐：考研院校录取分数查询）=====
# 基址（默认 https://yanbot.tech）
YANBOT_OPEN_BASE_URL=https://yanbot.tech
# 由 yanbot 后台生成的开放接口凭据
OPEN_API_KEY=
OPEN_API_SECRET=
# ===== 志愿推荐：自然语言需求解析 LLM（豆包 / 火山方舟 Ark，OpenAI 兼容接口）=====
# 火山方舟 API Key（Bearer）
DOUBAO_API_KEY=your_ark_api_key_here
# 可选：自定义 Base URL（默认北京区）
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 解析所用模型（建议用 lite 类小模型降低耗时）
RECOMMEND_MODEL=doubao-1-5-lite-32k-250115

# ===== 语音速查：火山引擎大模型流式语音识别（SAUC bigmodel，双向流式）=====
# 新版控制台：只需 X-Api-Key
VOLC_ASR_API_KEY=
# 旧版控制台：APP ID + Access Token（二选一套）
VOLC_ASR_APP_KEY=
VOLC_ASR_ACCESS_KEY=
# 可选：默认即双向流式 bigmodel（更优可用 bigmodel_async）
# VOLC_ASR_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
# VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration

